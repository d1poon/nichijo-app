# GitHub Personal Access Token（repo スコープが必要）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub リポジトリ情報
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-vault-repo-name
GITHUB_BRANCH=main

# vault 内の保存先フォルダ（末尾スラッシュなし）
VAULT_DAILY_PATH=Daily

# 「Obsidianで開く」ボタン用のvault名（obsidian://open?vault=XXX）
NEXT_PUBLIC_OBSIDIAN_VAULT=your-vault-name
